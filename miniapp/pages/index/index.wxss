.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.hero {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1677ff;
  display: block;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  display: block;
  line-height: 1.6;
}

.features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 60rpx;
}

.feature-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.feature-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 16rpx;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.login-section {
  text-align: center;
}

.btn-login {
  background: #1677ff;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  width: 100%;
  border: none;
}

.login-hint {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 16rpx;
}

.btn-start {
  background: #1677ff;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  border: none;
}
