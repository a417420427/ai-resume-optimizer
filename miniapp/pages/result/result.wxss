.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item:last-child {
  border-bottom: none;
}

.item-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-filename {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.item-type {
  font-size: 22rpx;
  color: #1677ff;
  background: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.item-time {
  font-size: 24rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
}

.btn-go {
  background: #1677ff;
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  display: inline-block;
  border: none;
}

.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}
