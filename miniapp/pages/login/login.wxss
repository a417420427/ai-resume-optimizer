.container {
  padding: 60rpx 40rpx;
  min-height: 100vh;
  background: #fff;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.tab-bar {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.tab {
  font-size: 30rpx;
  color: #999;
  padding: 16rpx 40rpx;
  border-bottom: 4rpx solid transparent;
}

.tab.active {
  color: #1677ff;
  border-bottom-color: #1677ff;
}

.form {
  max-width: 600rpx;
  margin: 0 auto;
}

.input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  line-height: 88rpx;
  border: none;
  margin-top: 16rpx;
}

.btn-submit[disabled] {
  background: #d9d9d9;
}
