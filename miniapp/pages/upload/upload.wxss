.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.upload-area {
  background: #fff;
  border: 2rpx dashed #d9d9d9;
  border-radius: 16rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.upload-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 12rpx;
}

.form {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  line-height: 80rpx;
}

.btn-submit {
  background: #1677ff;
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  border: none;
  margin-bottom: 30rpx;
}

.btn-submit.disabled {
  background: #d9d9d9;
}

.result {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.score-section {
  text-align: center;
  margin-bottom: 24rpx;
}

.score-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.score-value {
  font-size: 72rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.score-bar {
  margin-bottom: 20rpx;
}

.summary {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  display: block;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.suggestion-item {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.suggestion-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.suggestion-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.severity-high { background: #fff1f0; color: #ff4d4f; }
.severity-medium { background: #fff7e6; color: #fa8c16; }
.severity-low { background: #e6f7ff; color: #1890ff; }

.suggestion-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.suggestion-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.suggestion-advice {
  font-size: 26rpx;
  color: #1677ff;
  display: block;
}

.optimized-resume {
  margin-top: 30rpx;
}

.resume-preview {
  max-height: 600rpx;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.btn-new {
  margin-top: 30rpx;
  background: #fff;
  color: #1677ff;
  border: 1rpx solid #1677ff;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
}
